---
import Layout from "../../../layouts/Layout.astro";
import manifest from "../../../data/manifest.json";

export function getStaticPaths() {
  const paths: { params: { code: string; slug: string } }[] = [];
  for (const [code, papers] of Object.entries(manifest)) {
    for (const paper of papers as {date: string; file: string}[]) {
      paths.push({ params: { code, slug: encodeURIComponent(paper.file) } });
    }
  }
  return paths;
}

const base = import.meta.env.BASE_URL;
const { code, slug } = Astro.params;
const decoded = decodeURIComponent(slug!);
const allPapers = (manifest as any)[code!] as {date: string; file: string}[] || [];
const paper = allPapers.find((p) => p.file === decoded);
const dateLabel = paper?.date || decoded;
const pdfUrl = `${base}papers/${code}/${decoded}`;
---

<Layout title={`${code} — ${dateLabel}`} description={`View ${code} exam paper from ${dateLabel}`}>
  <div class="viewer-layout">
    <!-- Top bar -->
    <div class="viewer-bar">
      <div class="bar-left">
        <a href={`${base}subject/${code}/`} class="bar-back" title="Back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="bar-info">
          <span class="bar-code mono">{code}</span>
          <span class="bar-sep">·</span>
          <span class="bar-date">{dateLabel}</span>
        </div>
      </div>
      <div class="bar-right">
        <a href={pdfUrl} target="_blank" rel="noopener" class="bar-btn" title="Open in new tab">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <button id="dark-toggle" class="bar-btn" title="Toggle Dark Reader">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
        <a href={pdfUrl} download={decoded} class="dl-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span>Download</span>
        </a>
      </div>
    </div>

    <!-- PDF -->
    <div class="pdf-area">
      <iframe src={pdfUrl} class="pdf-frame" title={`${code} ${dateLabel}`}></iframe>
    </div>
  </div>
</Layout>

<script>
  const toggle = document.getElementById('dark-toggle');
  const frame = document.querySelector('.pdf-frame');
  const KEY = 'ku-pdf-dark-mode';
  
  if (localStorage.getItem(KEY) === 'true') {
    frame?.classList.add('dark-pdf');
  }

  toggle?.addEventListener('click', () => {
    frame?.classList.toggle('dark-pdf');
    localStorage.setItem(KEY, frame?.classList.contains('dark-pdf') ? 'true' : 'false');
  });
</script>

<style>
  .viewer-layout {
    display: flex; flex-direction: column;
    height: 100vh; overflow: hidden;
  }

  .viewer-bar {
    display: flex; align-items: center; justify-content: space-between;
    height: 52px; padding: 0 16px; flex-shrink: 0;
    background: rgba(20,20,20,0.9);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .bar-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .bar-back {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: var(--r-sm);
    color: var(--text-muted); flex-shrink: 0;
    border: 1px solid var(--border);
    transition: all var(--dur) var(--ease);
  }
  .bar-back:hover { border-color: var(--border-hover); color: var(--text); }

  .bar-info {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.82rem; min-width: 0;
  }
  .bar-code { font-weight: 600; color: var(--accent); flex-shrink: 0; font-size: 0.78rem; }
  .bar-sep { color: var(--text-faint); }
  .bar-date {
    color: var(--text-secondary); font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .bar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .bar-btn {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: var(--r-sm);
    color: var(--text-muted); border: 1px solid var(--border);
    transition: all var(--dur) var(--ease);
  }
  .bar-btn:hover { border-color: var(--border-hover); color: var(--text); }

  .dl-btn {
    display: inline-flex; align-items: center; gap: 7px;
    height: 32px; padding: 0 14px;
    background: var(--accent); color: var(--bg);
    border: none; border-radius: var(--r-sm);
    font-size: 0.78rem; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: all var(--dur) var(--ease);
  }
  .dl-btn:hover { opacity: 0.9; transform: translateY(-1px); }

  .pdf-area { flex: 1; overflow: hidden; background: #0e0e0e; }
  .pdf-frame { width: 100%; height: 100%; border: none; background: #fff; transition: filter var(--dur) var(--ease); }
  .pdf-frame.dark-pdf { filter: invert(0.92) hue-rotate(180deg) brightness(1.05) contrast(1.05); }

  @media (max-width: 640px) {
    .viewer-bar { padding: 0 12px; }
    .dl-btn span { display: none; }
    .dl-btn { width: 32px; padding: 0; justify-content: center; }
  }
</style>
