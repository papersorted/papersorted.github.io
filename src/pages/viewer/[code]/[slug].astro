---
import Layout from "../../../layouts/Layout.astro";
import { allContentEntries, findContentEntry } from "../../../data/contentCatalog.ts";

export function getStaticPaths() {
  return allContentEntries.map((entry) => ({
    params: {
      code: entry.code,
      slug: encodeURIComponent(entry.file),
    },
  }));
}

const base = import.meta.env.BASE_URL;
const { code, slug } = Astro.params;
const decoded = decodeURIComponent(slug!);
const entry = findContentEntry(code!, decoded);
const dateLabel = entry?.dateLabel || decoded;
const teacherLabel = entry?.kind === "internal" ? entry.teacher : undefined;
const documentKindLabel = entry?.kind === "internal" ? "internal paper" : "exam paper";
const assetType = entry?.assetType || "pdf";
const isPdfAsset = assetType === "pdf";
const assetUrl = `${base}${entry?.storageDir || "papers"}/${code}/${decoded}`;
const openLabel = isPdfAsset ? "Open PDF in new tab" : "Open image in new tab";
const downloadLabel = isPdfAsset ? "Download PDF" : "Download image";
---

<Layout title={`${code} — ${dateLabel}`} description={`View ${code} ${documentKindLabel} from ${dateLabel}`}>
  <div class="viewer-layout">
    <!-- Top bar -->
    <div class="viewer-bar">
      <div class="bar-left">
        <a href={`${base}subject/${code}/`} class="bar-back" title="Back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="bar-info">
          <span class="bar-code mono">{code}</span>
          <span class="bar-sep">·</span>
          <span class="bar-date">{dateLabel}</span>
          {teacherLabel && (
            <>
              <span class="bar-sep">·</span>
              <span class="bar-teacher">{teacherLabel}</span>
            </>
          )}
        </div>
      </div>
      <div class="bar-right">
        <button class="bar-btn theme-toggle-btn" title="Toggle Theme">
          <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        </button>
        <div class="dl-group">
          <a href={assetUrl} target="_blank" rel="noopener" class="bar-btn" title={openLabel}>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          <a href={assetUrl} download={decoded} class="dl-btn" title={downloadLabel}>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span>Download</span>
          </a>
        </div>
      </div>
    </div>

    <div class:list={["document-area", isPdfAsset ? "pdf-area" : "image-area"]} id="document-container">
      {isPdfAsset ? (
        <div id="pdf-loader" style="color:var(--text-faint); padding: 40px; font-family: monospace; text-align: center;">
          <div class="spinner"></div>
          <p id="loader-status">Loading PDF document...</p>
        </div>
      ) : (
        <div class="image-document-shell">
          <img
            id="document-image"
            src={assetUrl}
            alt={`${code} ${dateLabel}`}
            class="viewer-image"
            loading="eager"
            decoding="async"
          />
          <p id="image-load-error" class="image-load-error" hidden>
            Unable to load this image file.
          </p>
        </div>
      )}
    </div>
  </div>
</Layout>

{isPdfAsset && <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>}
{isPdfAsset && <input type="hidden" id="document-url-source" value={assetUrl} />}

{isPdfAsset && (
  <script is:inline>
    (function() {
      const container = document.getElementById('document-container');
      const status = document.getElementById('loader-status');
      const urlInput = document.getElementById('document-url-source');
      
      function log(msg, isError = false) {
        if (status) {
          status.innerHTML = msg;
          if (isError) status.style.color = '#ff6b6b';
        }
        console.log(`[PDF-INIT] ${msg}`);
      }

      async function start() {
        if (!window.pdfjsLib) {
          log("Unable to load the PDF viewer library.", true);
          return;
        }
        
        const sourceUrl = urlInput ? urlInput.value : '';
        if (!sourceUrl) {
          log("Document source URL is missing.", true);
          return;
        }

        const finalUrl = sourceUrl.startsWith('/') ? sourceUrl : '/' + sourceUrl;
        log("Rendering document...");

        try {
          const pdfjsLib = window.pdfjsLib;
          const loadingTask = pdfjsLib.getDocument({
            url: finalUrl,
            disableWorker: true
          });

          const pdf = await loadingTask.promise;
          const loader = document.getElementById('pdf-loader');
          if (loader) loader.style.display = 'none';

          for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
            const canvas = document.createElement('canvas');
            canvas.className = 'pdf-page-canvas';
            container.appendChild(canvas);

            const page = await pdf.getPage(pageNum);
            const unscaled = page.getViewport({ scale: 1.0 });
            const maxReadableWidth = 720;
            const availableWidth = Math.max(0, (container.clientWidth || window.innerWidth) - 24);
            const cw = Math.min(unscaled.width, maxReadableWidth, availableWidth);
            const logicalScale = cw / unscaled.width;
            const pixelRatio = window.devicePixelRatio || 1;
            const viewport = page.getViewport({ scale: logicalScale * pixelRatio });
            
            const ctx = canvas.getContext('2d');
            canvas.height = viewport.height;
            canvas.width = viewport.width;
            canvas.style.width = cw + 'px';
            canvas.style.height = ((viewport.height / viewport.width) * cw) + 'px';
            
            await page.render({ canvasContext: ctx, viewport: viewport }).promise;
          }
        } catch (err) {
          const message = err instanceof Error ? err.message : "Unknown error";
          log(`Unable to render this PDF: ${message}`, true);
          console.error(err);
        }
      }

      if (document.readyState === 'complete') {
        start();
      } else {
        window.addEventListener('load', start);
      }
    })();
  </script>
)}

<style>
  .spinner {
    width: 24px; height: 24px; border: 2px solid var(--accent);
    border-top-color: transparent; border-radius: 50%;
    margin: 0 auto 12px; animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

{isPdfAsset && (
  <script>
    const pdfContainer = document.querySelector('.pdf-area');
    
    function syncPDFTheme() {
      const isDark = !document.documentElement.classList.contains('light');
      pdfContainer?.classList.toggle('dark-pdf', isDark);
    }

    const observer = new MutationObserver((mutations) => {
      mutations.forEach((m) => {
        if (m.attributeName === 'class') syncPDFTheme();
      });
    });

    observer.observe(document.documentElement, { attributes: true });
    syncPDFTheme();
  </script>
)}

{!isPdfAsset && (
  <script is:inline>
    (function() {
      const image = document.getElementById('document-image');
      const error = document.getElementById('image-load-error');

      if (!image || !error) return;

      image.addEventListener('error', () => {
        image.style.display = 'none';
        error.hidden = false;
      });
    })();
  </script>
)}

<style>
  .viewer-layout {
    display: flex; flex-direction: column;
    height: 100vh; overflow: hidden;
  }

  .viewer-bar {
    display: flex; align-items: center; justify-content: space-between;
    height: 52px; padding: 0 16px; flex-shrink: 0;
    background: var(--viewer-bar-bg);
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    border-bottom: 1px solid var(--border);
    transition:
      background-color var(--theme-dur) var(--theme-ease),
      border-color var(--theme-dur) var(--theme-ease),
      box-shadow var(--theme-dur) var(--theme-ease);
  }

  .bar-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .bar-back {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: var(--r-sm);
    color: var(--text-muted); flex-shrink: 0;
    border: 1px solid var(--border);
    transition: all var(--dur) var(--ease);
  }
  .bar-back:hover { border-color: var(--border-hover); color: var(--text); }

  .bar-info {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.82rem; min-width: 0;
  }
  .bar-code { font-weight: 600; color: var(--accent); flex-shrink: 0; font-size: 0.78rem; }
  .bar-sep { color: var(--text-faint); }
  .bar-date {
    color: var(--text-secondary); font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .bar-teacher {
    color: var(--text-muted);
    font-size: 0.78rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .dl-group { display: flex; align-items: center; gap: 8px; }
  .bar-btn {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: var(--r-sm);
    color: var(--text-secondary); border: 1px solid var(--border);
    background: transparent; cursor: pointer; padding: 0;
    transition: all var(--dur) var(--ease);
  }
  .bar-btn:hover { border-color: var(--border-hover); color: var(--text); background: var(--bg-card-hover); }
  .viewer-bar .theme-toggle-btn::before {
    display: none;
  }
  .viewer-bar .theme-toggle-btn .moon,
  .viewer-bar .theme-toggle-btn .sun {
    filter: none;
  }

  .dl-btn {
    display: inline-flex; align-items: center; gap: 7px;
    height: 32px; padding: 0 14px;
    background: var(--accent); color: var(--bg);
    border: none; border-radius: var(--r-sm);
    font-size: 0.78rem; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: all var(--dur) var(--ease);
  }
  .dl-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  :root.light .dl-btn {
    background: #2a2a2a;
    color: #f5f0e8;
    border: 1px solid #2a2a2a;
  }
  :root.light .dl-btn:hover {
    background: #343434;
    border-color: #343434;
    color: #f5f0e8;
  }

  .document-area {
    flex: 1; overflow-y: auto;
    background: linear-gradient(180deg, var(--viewer-bg-top) 0%, var(--viewer-bg) 100%);
    display: flex; flex-direction: column; align-items: center; 
    gap: 16px; padding: 24px 12px;
    transition: background var(--theme-dur) var(--theme-ease);
  }

  .image-document-shell {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .viewer-image {
    width: min(100%, 720px);
    max-width: 720px;
    height: auto;
    display: block;
    margin: 0 auto;
    box-shadow: 0 10px 32px rgba(0,0,0,0.24);
    background: #fff;
  }

  .image-load-error {
    color: #c26a6a;
    font-size: 0.84rem;
    text-align: center;
    margin: 0;
  }
  
  /* Use :global here so Astro Compiler doesn't strip it from final bundle since canvases are dynamically created */
  :global(.pdf-page-canvas) { 
    max-width: min(100%, 720px);
    height: auto;
    display: block;
    margin: 0 auto;
    box-shadow: 0 10px 32px rgba(0,0,0,0.24);
    background: #fff;
    transition:
      filter var(--theme-dur) var(--theme-ease),
      box-shadow var(--theme-dur) var(--theme-ease);
  }
  
  :global(.dark-pdf) :global(.pdf-page-canvas) { 
    filter: invert(0.92) hue-rotate(180deg) brightness(1.05) contrast(1.05);
    box-shadow: 0 0 40px rgba(0,0,0,0.4);
  }

  @media (max-width: 640px) {
    .viewer-bar {
      padding: 0 12px;
      border-bottom-color: #3a3a3a;
    }
    .bar-back,
    .bar-btn,
    .dl-btn {
      border: none !important;
      background: transparent !important;
      box-shadow: none;
    }
    .bar-back {
      color: var(--text-muted);
    }
    .bar-btn,
    .dl-btn {
      color: var(--text-secondary);
    }
    .bar-back:hover,
    .bar-btn:hover,
    .dl-btn:hover {
      border-color: transparent;
      background: transparent !important;
      color: var(--text);
      transform: none;
    }
    .dl-btn span { display: none; }
    .dl-btn { width: 32px; padding: 0; justify-content: center; }
    :root.light .bar-back {
      color: #8c8882;
    }
    :root.light .bar-btn,
    :root.light .dl-btn {
      color: #5e5a54;
    }
    :root.light .bar-back:hover,
    :root.light .bar-btn:hover,
    :root.light .dl-btn:hover {
      color: #2d2a26;
    }
    :root.light .viewer-bar {
      border-bottom-color: rgba(0, 0, 0, 0.1);
    }
    .viewer-image {
      width: min(100%, 720px);
    }
    .bar-teacher {
      display: none;
    }
  }
</style>
