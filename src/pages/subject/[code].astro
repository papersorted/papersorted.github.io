---
import Layout from "../../layouts/Layout.astro";
import manifest from "../../data/manifest.json";

export function getStaticPaths() {
  return Object.keys(manifest).map((code) => ({ params: { code } }));
}

const base = import.meta.env.BASE_URL;
const { code } = Astro.params;
const papers = (manifest as any)[code!] as {date: string; file: string}[] || [];

// Month order for sorting
const monthOrder: Record<string, number> = {
  Jan: 1, Feb: 2, Mar: 3, Apr: 4, May: 5, Jun: 6,
  Jul: 7, Aug: 8, Sep: 9, Oct: 10, Nov: 11, Dec: 12,
};

function parseDate(dateStr: string): { year: number; monthIdx: number } {
  const yearMatch = dateStr.match(/(\d{4})/);
  const year = yearMatch ? parseInt(yearMatch[1]) : 0;

  // Get the first month mentioned (e.g., "May-Jun" → "May", "Sep" → "Sep")
  const monthMatch = dateStr.match(/([A-Za-z]+)/);
  const firstMonth = monthMatch ? monthMatch[1] : "";
  const monthIdx = monthOrder[firstMonth] || 0;

  return { year, monthIdx };
}

// Group papers by year
const yearGroups: Record<number, {date: string; file: string; monthIdx: number}[]> = {};
for (const p of papers) {
  const { year, monthIdx } = parseDate(p.date);
  if (!yearGroups[year]) yearGroups[year] = [];
  yearGroups[year].push({ ...p, monthIdx });
}

// Sort years descending, months ascending within each year
const sortedYears = Object.keys(yearGroups)
  .map(Number)
  .sort((a, b) => b - a);

for (const year of sortedYears) {
  yearGroups[year].sort((a, b) => a.monthIdx - b.monthIdx);
}
---

<Layout title={code!} description={`Past examination papers for ${code}`}>
  <main class="container">
    <nav class="breadcrumb anim">
      <a href={base}>Home</a>
      <span class="sep">›</span>
      <span class="current">{code}</span>
    </nav>

    <header class="page-head anim" style="animation-delay:60ms">
      <h1 class="page-title serif">{code}</h1>
      <p class="page-sub">{papers.length} examination paper{papers.length !== 1 ? "s" : ""}</p>
    </header>

    <div class="years-list">
      {sortedYears.map((year, yi) => (
        <section class="year-group anim" style={`animation-delay:${120 + yi * 60}ms`}>
          <div class="year-header">
            <span class="year-label serif">{year}</span>
            <span class="year-count">{yearGroups[year].length}</span>
          </div>
          <div class="year-papers">
            {yearGroups[year].map((paper) => {
              const href = `${base}viewer/${code}/${encodeURIComponent(paper.file)}/`;
              return (
                <a href={href} class="paper">
                  <div class="paper-left">
                    <div class="paper-icon">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg>
                    </div>
                    <span class="paper-date">{paper.date}</span>
                  </div>
                  <div class="paper-arrow">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m9 18 6-6-6-6" />
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </div>

    <div class="contribute-block anim" style={`animation-delay:${120 + sortedYears.length * 60 + 30}ms`}>
      <p>Missing a paper?</p>
      <a href={`https://github.com/papersorted/papersorted.github.io/issues/new?title=[New+Paper]+${code}&body=Please+attach+the+PDF+file+for+${code}+here.`} target="_blank" rel="noopener" class="contribute-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Submit PDF
      </a>
    </div>

    <div class="back-section anim" style={`animation-delay:${120 + sortedYears.length * 60 + 60}ms`}>
      <a href={base} class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All subjects
      </a>
    </div>
  </main>
</Layout>

<style>

  .page-head { padding: 40px 0 36px; border-bottom: 1px solid var(--border); }
  .page-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700; line-height: 1; letter-spacing: -0.01em;
    color: var(--text); margin-bottom: 12px;
  }
  .page-sub { font-size: 0.85rem; color: var(--text-muted); }

  /* ── Year groups ── */
  .years-list {
    display: flex; flex-direction: column;
    padding: 8px 0 24px;
  }

  .year-group {
    padding-top: 28px;
  }
  .year-group:first-child { padding-top: 20px; }

  .year-header {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .year-label {
    font-size: 1.5rem; color: var(--text); line-height: 1;
  }
  .year-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 22px; height: 22px; padding: 0 7px;
    background: var(--accent-dim); border-radius: 100px;
    font-size: 0.68rem; font-weight: 600; color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .year-papers {
    display: flex; flex-direction: column;
  }

  /* ── Paper row ── */
  .paper {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 0; padding-left: 0;
    border-bottom: 1px solid var(--border);
    transition: all var(--dur) var(--ease);
    cursor: pointer;
  }
  .paper:hover { padding-left: 8px; }

  .paper-left { display: flex; align-items: center; gap: 12px; }
  .paper-icon {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: var(--accent-dim); color: var(--accent);
    border-radius: var(--r-sm); flex-shrink: 0;
  }
  .paper-date {
    font-size: 0.88rem; font-weight: 500; color: var(--text);
  }

  .paper-arrow {
    color: var(--text-faint); flex-shrink: 0;
    transition: all var(--dur) var(--ease);
  }
  .paper:hover .paper-arrow { color: var(--accent); transform: translateX(3px); }

  /* ── Contribute ── */
  .contribute-block {
    margin: 32px 0 16px; padding: 24px;
    background: var(--bg-card); border: 1px dashed var(--border-hover);
    border-radius: var(--r); text-align: center;
  }
  .contribute-block p {
    font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 12px;
  }
  .contribute-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    padding: 8px 16px; background: var(--bg-card); color: var(--text);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    font-size: 0.8rem; font-weight: 500; font-family: inherit;
    cursor: pointer; transition: all var(--dur) var(--ease);
  }
  .contribute-btn:hover {
    background: var(--accent); color: var(--bg); border-color: var(--accent);
  }

  /* ── Back ── */
  .back-section { padding: 12px 0 80px; }
  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.82rem; font-weight: 500; color: var(--text-muted);
    transition: color var(--dur) var(--ease);
  }
  .back-link:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .page-head { padding: 28px 0 24px; }
    .year-label { font-size: 1.25rem; }
    .paper { padding: 12px 0; }
    .paper-icon { width: 32px; height: 32px; }
  }
</style>

<script define:vars={{ code }}>
  const RECENT_KEY = 'ku-recent';
  const RECENT_VIEW_KEY = 'ku-recent-enabled';

  if (localStorage.getItem(RECENT_VIEW_KEY) === 'false') {
    localStorage.removeItem(RECENT_KEY);
  } else {
    let history;
    try {
      const rawHistory = localStorage.getItem(RECENT_KEY);
      const parsedHistory = rawHistory ? JSON.parse(rawHistory) : [];
      history = Array.isArray(parsedHistory) ? parsedHistory : [];
    } catch {
      localStorage.removeItem(RECENT_KEY);
      history = [];
    }
    history = history.filter(c => c !== code);
    history.unshift(code);
    if (history.length > 6) history.pop();
    localStorage.setItem(RECENT_KEY, JSON.stringify(history));
  }
</script>
