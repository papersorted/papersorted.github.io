---
import Layout from "../layouts/Layout.astro";
import manifest from "../data/manifest.json";
import { programs } from "../data/programs.ts";

const data = manifest as Record<string, {date: string; file: string}[]>;
const subjects = Object.keys(data).sort();
const totalPapers = Object.values(data).reduce((s, a) => s + a.length, 0);

interface CardInfo {
  code: string;
  count: number;
}

const cards: CardInfo[] = subjects.map((code) => ({
  code,
  count: data[code].length,
}));
---

<Layout title="Exam Papers">
  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <p class="hero-tag anim">Kathmandu University</p>
      <h1 class="hero-title serif anim" style="animation-delay:60ms">Exam Papers</h1>
      <p class="hero-sub anim" style="animation-delay:120ms">
        {subjects.length} subjects · {totalPapers.toLocaleString()} papers
      </p>
    </div>
  </header>

  <!-- Search -->
  <div class="container">
    <div class="search-section anim" style="animation-delay:180ms">
      <div class="search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="search-input" placeholder="Search subjects…" autocomplete="off" spellcheck="false" />
        <kbd>/</kbd>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="container anim" style="animation-delay:200ms; margin-top: 16px;">
    <div class="program-filter">
      <select id="program-select" class="dropdown">
        <option value="none">All Programs</option>
        {Object.keys(programs).sort().map((prog) => (
          <option value={prog}>{prog}</option>
        ))}
      </select>
    </div>

    <div class="filters-scroll" id="semester-wrapper" style="display:none; margin-top: 12px;">
      <div class="filters" id="semester-filters">
        <button class="filter-btn active" data-sem="all">All Semesters</button>
        {Object.entries(programs).map(([progName, sems]) => (
          sems.map((sem) => (
             <button class="filter-btn sem-btn" style="display:none;" data-prog={progName} data-sem={sem.semester} data-subjects={sem.subjects.join(",")}>
               Sem {sem.semester}
             </button>
          ))
        ))}
      </div>
    </div>
  </div>

  <!-- Subjects -->
  <main class="container">
    <div class="grid-head">
      <span class="grid-label" id="results-count">All subjects</span>
    </div>

    <div class="grid" id="subject-grid">
      {cards.map((c, i) => (
        <div class="card anim" style={`animation-delay:${Math.min(200 + i * 10, 650)}ms`} data-code={c.code}>
          <a href={`/subject/${c.code}/`} class="card-link">
            <span class="card-code mono">{c.code}</span>
            <span class="card-papers">{c.count} paper{c.count !== 1 ? "s" : ""}</span>
          </a>
          <button class="star-btn" aria-label="Favorite" title="Add to Favorites">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="star-icon" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
          </button>
        </div>
      ))}
    </div>

    <div class="empty" id="no-results" style="display:none">
      <p>No subjects match your search.</p>
    </div>
  </main>

  <footer class="foot">
    <div class="container foot-inner">
      <span>KU Exam Archive</span>
      <span class="foot-dot">·</span>
      <a href="https://github.com/papersorted/papersorted.github.io/issues/new" target="_blank" rel="noopener" class="foot-link">Contribute Papers</a>
    </div>
  </footer>
</Layout>

<style>
  /* ── HERO ── */
  .hero {
    padding: 72px 0 12px;
    border-bottom: 1px solid var(--border);
  }
  .hero-tag {
    font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.18em; color: var(--accent); margin-bottom: 16px;
  }
  .hero-title {
    font-size: clamp(3.2rem, 9vw, 6rem);
    font-weight: 500; line-height: 1; letter-spacing: -0.03em;
    color: #ffffff; margin-bottom: 20px;
  }
  .hero-sub {
    font-size: 0.95rem; color: var(--text-secondary); font-weight: 400;
    padding-bottom: 48px;
  }

  /* ── SEARCH ── */
  .search-section { padding: 24px 0 0; }
  .search-box {
    display: flex; align-items: center; gap: 10px;
    height: 44px; padding: 0 14px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .search-box svg { color: var(--text-muted); flex-shrink: 0; }
  .search-box:focus-within {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 2px rgba(201,168,124,0.08);
  }
  .search-box input {
    flex: 1; background: none; border: none; outline: none;
    font-family: inherit; font-size: 0.85rem;
    color: var(--text); font-weight: 400;
  }
  .search-box input::placeholder { color: var(--text-muted); }
  .search-box kbd {
    display: inline-flex; align-items: center; justify-content: center;
    width: 22px; height: 22px;
    background: rgba(255,255,255,0.04); border: 1px solid var(--border);
    border-radius: 4px; font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem; font-weight: 500; color: var(--text-muted);
  }

  /* ── PROGRAM DROPDOWN ── */
  .program-filter { display: flex; align-items: center; width: 100%; min-width: 0; }
  .dropdown {
    width: 100%; max-width: 100%;
    text-overflow: ellipsis; overflow: hidden; white-space: nowrap;
    background: var(--bg-card); color: var(--text);
    border: 1px solid var(--border); border-radius: var(--r-sm);
    padding: 8px 18px 8px 14px; font-size: 0.85rem; font-family: inherit; font-weight: 500;
    cursor: pointer; transition: all var(--dur) var(--ease); outline: none;
    -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23a39e98%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat; background-position: right 14px top 55%; background-size: 10px auto;
    padding-right: 36px;
  }
  .dropdown:hover { border-color: var(--border-hover); background-color: var(--bg-card-hover); }
  .dropdown:focus { border-color: var(--border-focus); box-shadow: 0 0 0 2px rgba(201,168,124,0.08); }

  /* ── FILTERS ── */
  .filters-scroll {
    overflow-x: auto; padding-bottom: 8px; margin-bottom: -8px;
    scrollbar-width: none;
  }
  .filters-scroll::-webkit-scrollbar { display: none; }
  .filters {
    display: flex; gap: 8px; align-items: center; white-space: nowrap;
  }
  .filter-btn {
    background: var(--bg-card); color: var(--text-secondary);
    border: 1px solid var(--border); border-radius: 20px;
    padding: 6px 14px; font-size: 0.78rem; font-family: inherit; font-weight: 500;
    cursor: pointer; transition: all var(--dur) var(--ease);
  }
  .filter-btn:hover {
    background: var(--bg-card-hover); border-color: var(--border-hover); color: var(--text);
  }
  .filter-btn.active {
    background: var(--accent); color: var(--bg); border-color: var(--accent);
  }

  /* ── GRID ── */
  .grid-head { padding: 28px 0 14px; }
  .grid-label {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-faint);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
    gap: 6px;
    padding-bottom: 80px;
  }

  .card {
    position: relative;
    height: 88px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    transition: all var(--dur) var(--ease);
  }
  .card:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    box-shadow: var(--shadow-card);
    transform: translateY(-1px);
  }
  .card:active { transform: translateY(0); transition-duration: 0.06s; }
  .card-link {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 16px; padding-right: 48px; outline: none;
  }
  .card-code {
    font-size: 0.88rem; font-weight: 500;
    letter-spacing: 0.01em; color: var(--text);
  }
  .card-papers {
    font-size: 0.7rem; font-weight: 400; color: var(--text-muted);
  }
  
  .star-btn {
    position: absolute; top: 12px; right: 12px; z-index: 10;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: none; color: var(--text-faint);
    cursor: auto; border-radius: 50%;
    transition: all var(--dur) var(--ease);
  }
  /* The anchor captures clicks generally, we intercept star-btn clicks inside the script,
     but we want the pointer cursor to apply cleanly over the whole card. */
  .star-btn:hover { color: var(--accent); background: var(--bg-card-hover); }
  .card.favorited .star-btn { color: var(--accent); }
  .card.favorited .star-icon { fill: var(--accent); stroke: var(--accent); }

  /* ── EMPTY ── */
  .empty {
    text-align: center; padding: 60px 0;
    font-size: 0.85rem; color: var(--text-muted);
  }

  /* ── FOOTER ── */
  .foot { border-top: 1px solid var(--border); padding: 28px 0; }
  .foot-inner {
    display: flex; justify-content: center; gap: 8px;
    font-size: 0.75rem; color: var(--text-faint); font-weight: 500;
  }
  .foot-dot { opacity: 0.4; }
  .foot-link { color: var(--text-muted); transition: color var(--dur) var(--ease); }
  .foot-link:hover { color: var(--accent); }

  @media (max-width: 640px) {
    .hero { padding: 48px 0 8px; }
    .hero-title { font-size: 2.4rem; }
    .hero-sub { padding-bottom: 32px; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 5px; }
    .card { height: 76px; padding: 13px; }
  }
</style>

<script>
  const input = document.getElementById("search-input") as HTMLInputElement;
  const grid = document.getElementById("subject-grid")!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>(".card"));
  const label = document.getElementById("results-count")!;
  const empty = document.getElementById("no-results")!;
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
  
  const progSelect = document.getElementById("program-select") as HTMLSelectElement;
  const semWrapper = document.getElementById("semester-wrapper")!;
  const semBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".sem-btn"));
  const allSemBtn = document.querySelector<HTMLButtonElement>("[data-sem='all']")!;

  let activeSubjects: string[] | null = null;
  const FAV_KEY = 'ku-favorites';
  let favorites: Set<string> = new Set(JSON.parse(localStorage.getItem(FAV_KEY) || '[]'));

  function saveFavorites() {
    localStorage.setItem(FAV_KEY, JSON.stringify(Array.from(favorites)));
  }

  function renderFavorites() {
    // Determine the sorting reference Array.
    // If we map over `cards`, we process the DOM elements.
    cards.forEach(c => {
      const code = c.dataset.code || "";
      if (favorites.has(code)) {
        c.classList.add('favorited');
        // By using CSS order, we don't have to strictly mutate the DOM blindly, but `.prepend` is cleaner.
        grid.prepend(c);
      } else {
        c.classList.remove('favorited');
        // If not favorited, we leave it where it belongs. To properly reset, we need to re-append natively.
        // Easiest is to append everything not favorited in their original alphabetical order.
        grid.appendChild(c);
      }
    });
    // Now just re-prepend all favorites so they are stacked at the very top.
    const favCards = cards.filter(c => favorites.has(c.dataset.code || ""));
    // To retain alphabetical order of favorites, we actually append them in reverse or preserve order.
    // Since cards array is originally alphabetical:
    cards.forEach(c => { if (!favorites.has(c.dataset.code||"")) grid.appendChild(c); });
    favCards.forEach(c => grid.prepend(c)); 
  }

  // Setup Star button handlers
  cards.forEach(c => {
    const btn = c.querySelector('.star-btn')!;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const code = c.dataset.code || "";
      if (favorites.has(code)) favorites.delete(code);
      else favorites.add(code);
      saveFavorites();
      renderFavorites();
      update();
    });
  });

  renderFavorites();

  function update() {
    const q = input.value.trim().toUpperCase();
    let n = 0;
    for (const c of cards) {
      const code = c.dataset.code || "";
      const matchSearch = !q || code.includes(q);
      const matchFilter = !activeSubjects || activeSubjects.includes(code);
      
      const show = matchSearch && matchFilter;
      c.style.display = show ? "" : "none";
      if (show) n++;
    }
    label.textContent = q || activeSubjects ? `${n} result${n !== 1 ? "s" : ""}` : "All subjects";
    empty.style.display = n === 0 ? "" : "none";
  }

  progSelect.addEventListener("change", () => {
    const prog = progSelect.value;
    if (prog === "none") {
      semWrapper.style.display = "none";
      activeSubjects = null;
    } else {
      semWrapper.style.display = "";
      let allSubsGradiant: string[] = [];
      semBtns.forEach(btn => {
        const match = btn.dataset.prog === prog;
        btn.style.display = match ? "" : "none";
        if (match) {
           allSubsGradiant.push(...btn.dataset.subjects!.split(","));
        }
      });
      allSemBtn.dataset.subjects = allSubsGradiant.join(",");
      allSemBtn.click(); // Trigger the click to apply the filter
    }
    update();
  });

  filterBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      filterBtns.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      
      const sem = btn.dataset.sem;
      if (sem === "all") {
         activeSubjects = btn.dataset.subjects ? btn.dataset.subjects.split(",") : null;
      } else {
         activeSubjects = btn.dataset.subjects!.split(",");
      }
      update();
    });
  });

  input.addEventListener("input", update);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") { input.value = ""; update(); input.blur(); }
    if (e.key === "/" && document.activeElement !== input) { e.preventDefault(); input.focus(); }
  });
</script>
