---
import Layout from "../layouts/Layout.astro";
import { allSubjectCodes, getSubjectDocumentCount, totalDocumentCount } from "../data/contentCatalog.ts";
import { programs } from "../data/programs.ts";

const subjects = allSubjectCodes;
const totalPapers = totalDocumentCount;

interface CardInfo {
  code: string;
  count: number;
}

interface SemesterFilterInfo {
  semester: string;
  label: string;
  subjects: string[];
}

const cards: CardInfo[] = subjects.map((code) => ({
  code,
  count: getSubjectDocumentCount(code),
}));

const availableSubjects = new Set(subjects);

function uniqueAvailableSubjects(subjectCodes: string[]) {
  return Array.from(new Set(subjectCodes)).filter((subject) => availableSubjects.has(subject));
}

function formatSemesterLabel(value: string) {
  const [year, semester] = value.split("/");
  if (!year || !semester) return `Semester ${value}`;
  return `Year ${year} · Semester ${semester}`;
}

const programFilters: Record<string, SemesterFilterInfo[]> = Object.fromEntries(
  Object.entries(programs).map(([programName, semesters]) => [
    programName,
    semesters.map((semester) => ({
      semester: semester.semester,
      label: formatSemesterLabel(semester.semester),
      subjects: uniqueAvailableSubjects(semester.subjects),
    })),
  ]),
);

---

<Layout title="Exam Papers" bodyClass="home-page">
  <div class="home-page">
    <!-- Hero -->
    <header class="hero">
      <div class="container hero-shell">
        <div class="hero-top">
          <div class="hero-text">
            <p class="hero-tag anim">Kathmandu University</p>
            <h1 class="hero-title anim">
              <span class="hero-title-line">Exam</span>
              <span class="hero-title-line">Papers</span>
            </h1>
            <p class="hero-sub anim" style="animation-delay:120ms">
              <span class="hero-stat"><strong>{subjects.length}</strong> <span>subjects</span></span>
              <span class="hero-sub-dot" aria-hidden="true">&middot;</span>
              <span class="hero-stat"><strong>{totalPapers.toLocaleString()}</strong> <span>papers</span></span>
            </p>
          </div>
          <div class="hero-tools anim" style="animation-delay:150ms">
            <button class="hero-theme-btn theme-toggle-btn" title="Toggle Theme">
              <svg class="moon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
              <svg class="sun" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
            </button>
          </div>
        </div>
        <div class="search-section anim" style="animation-delay:180ms">
          <div class="search-box">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="text" id="search-input" placeholder="Search by code or subject area..." autocomplete="off" spellcheck="false" />
            <kbd>/</kbd>
          </div>
        </div>
      </div>
    </header>

    <!-- Recently Viewed -->
    <div class="container anim recent-section" id="recent-container" style="display: none; animation-delay:190ms">
      <div class="grid-head recent-head">
        <span class="grid-label">Recently Viewed</span>
        <button id="clear-recent" class="clear-btn" title="Clear history">Clear</button>
      </div>
      <div class="recent-scroll" id="recent-carousel"></div>
    </div>

    <!-- Filters -->
    <div class="container anim filters-section" style="animation-delay:200ms;">
      <div class="program-filter">
        <select id="program-select" class="dropdown">
          <option value="none">All Programs</option>
          {Object.keys(programFilters).sort().map((prog) => (
            <option value={prog}>{prog}</option>
          ))}
        </select>
      </div>

      <div class="filters-scroll" id="semester-wrapper" style="display:none; margin-top: 12px;">
        <div class="filters" id="semester-filters">
          <button class="filter-btn active" type="button" data-sem="all" data-label="All Semesters">All Semesters</button>
          {Object.entries(programFilters).map(([progName, sems]) => (
            sems.map((sem) => (
               <button
                 class="filter-btn sem-btn"
                 type="button"
                 style="display:none;"
                 data-prog={progName}
                 data-sem={sem.semester}
                 data-label={sem.label}
                 data-subjects={sem.subjects.join(",")}
               >
                 {sem.label}
               </button>
            ))
          ))}
        </div>
      </div>
    </div>

    <!-- Subjects -->
    <main class="container">
    <div class="grid-head">
      <span class="grid-label" id="results-count">All subjects</span>
    </div>

    <div class="grid" id="subject-grid">
      {cards.map((c, i) => (
        <div class="card anim" style={`animation-delay:${Math.min(200 + i * 10, 650)}ms`} data-code={c.code}>
          <a href={`/subject/${c.code}/`} class="card-link">
            <span class="card-code mono">{c.code}</span>
            <span class="card-papers">
              {c.count} paper{c.count !== 1 ? "s" : ""}
              {c.count >= 5 && <span class="paper-density" aria-hidden="true"></span>}
            </span>
          </a>
          <div class="card-actions">
            <button class="star-btn" aria-label="Favorite" title="Add to Favorites">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="star-icon" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            </button>
          </div>
        </div>
      ))}
    </div>



    <div class="empty" id="no-results" style="display:none">
      <p>No subjects match your search.</p>
    </div>
  </main>

    <footer class="foot">
      <div class="container foot-inner">
        <div class="foot-copy">
          <p class="foot-label">Papersorted</p>
          <p class="foot-note">&copy; 2026 &middot; All rights reserved</p>
        </div>
        <a href="https://github.com/papersorted/papersorted.github.io/issues/new" target="_blank" rel="noopener" class="foot-link">
          <span>Contribute Papers</span>
          <span class="foot-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </footer>
  </div>
</Layout>

<style>
  :global(:root) {
    background: #2a2a2a;
  }
  :global(:root.light) {
    background: #f5f4ef;
  }
  :global(body.home-page) {
    --home-bg: #2a2a2a;
    --home-text: #f0ebe0;
    --home-muted: #888888;
    --home-card: #333333;
    --home-surface: #3a3a3a;
    --home-border: #444444;
    --grain-opacity: 0;
    background: var(--home-bg);
    color: var(--home-text);
  }
  :global(:root.light body.home-page) {
    --home-bg: #f5f4ef;
    --home-text: #2d2a26;
    --home-muted: #8a857e;
    --home-card: #ffffff;
    --home-surface: #f7f2ea;
    --home-border: rgba(0, 0, 0, 0.1);
  }
  :global(body.home-page)::after {
    content: "";
    display: block;
    opacity: 0.06;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 220 220' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.6' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23grain)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
    background-position: -7px -5px;
    mix-blend-mode: soft-light;
    filter: contrast(140%) brightness(104%);
  }

  .home-page {
    min-height: 100vh;
    background: transparent;
  }
  .home-page .container {
    max-width: 900px;
    padding-left: 48px;
    padding-right: 48px;
  }
  .home-page .theme-toggle-btn::before {
    content: none;
  }
  .home-page .theme-toggle-btn .moon,
  .home-page .theme-toggle-btn .sun {
    filter: none;
  }

  /* ── HERO ── */
  .hero {
    padding: 40px 0 0;
  }
  .hero::before {
    content: none;
  }
  :root.light .hero::before {
    content: none;
  }
  .hero-shell {
    display: grid;
    gap: 28px;
  }
  .hero-top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 32px;
  }
  .hero-text {
    max-width: 100%;
    padding-top: 0;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
    color: var(--home-muted);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .hero-tag::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--home-muted);
    opacity: 1;
  }
  .hero-title {
    display: grid;
    gap: 0;
    width: max-content;
    max-width: 100%;
    margin-bottom: 20px;
    color: var(--home-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(4.5rem, 9.4vw, 7.5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.045em;
  }
  .hero-title-line {
    display: block;
  }
  .hero-title-line:last-child {
    margin-left: 0;
  }
  .hero-sub {
    display: flex;
    align-items: center;
    flex-wrap: nowrap;
    gap: 10px;
    width: max-content;
    max-width: 100%;
    color: var(--home-muted);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0;
  }
  .hero-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }
  .hero-stat strong {
    color: var(--home-text);
    font-weight: 700;
  }
  .hero-sub-dot {
    color: var(--home-muted);
    font-size: 1rem;
    line-height: 1;
  }
  .hero-tools {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    padding-top: 2px;
  }
  .hero-theme-btn {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid var(--home-border);
    background: var(--home-card);
    color: var(--home-text);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .hero-theme-btn:hover {
    border-color: var(--home-muted);
    background: var(--home-card);
    color: var(--home-text);
    transform: none;
  }

  /* ── SEARCH ── */
  .search-section {
    width: 100%;
    margin-top: 0;
  }
  .search-box {
    display: flex;
    align-items: center;
    gap: 12px;
    height: 56px;
    padding: 0 18px;
    background: var(--home-surface);
    border: 1px solid var(--home-border);
    border-radius: 999px;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .search-box svg { color: var(--home-muted); flex-shrink: 0; }
  .search-box:focus-within {
    border-color: var(--home-muted);
  }
  .search-box input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--home-text);
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 400;
  }
  .search-box input::placeholder { color: var(--home-muted); }
  .search-box kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border: 1px solid var(--home-border);
    border-radius: 8px;
    background: var(--home-card);
    color: var(--home-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
  }

  /* ── PROGRAM DROPDOWN ── */
  .recent-section,
  .filters-section,
  main.container {
    margin-top: 30px;
  }
  .recent-head {
    padding: 0 0 14px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .program-filter { display: flex; align-items: center; width: 100%; min-width: 0; }
  .dropdown {
    width: 100%; max-width: 100%;
    text-overflow: ellipsis; overflow: hidden; white-space: nowrap;
    background: var(--home-card);
    color: var(--home-text);
    border: 1px solid var(--home-border);
    border-radius: 16px;
    padding: 14px 18px 14px 16px;
    font-size: 0.95rem;
    font-family: inherit;
    font-weight: 400;
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease), background-color var(--dur) var(--ease);
    outline: none;
    -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%228%22%20viewBox%3D%220%200%2012%208%22%3E%3Cpath%20fill%3D%22%23888888%22%20d%3D%22M1.41.59%206%205.17%2010.59.59%2012%202l-6%206-6-6z%22%2F%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat; background-position: right 14px top 55%; background-size: 10px auto;
    padding-right: 36px;
  }
  .dropdown:hover,
  .dropdown:focus {
    border-color: var(--home-muted);
    background-color: var(--home-card);
  }

  /* ── FILTERS ── */
  .filters-scroll {
    overflow-x: auto; padding-bottom: 8px; margin-top: 14px; margin-bottom: -8px;
    scrollbar-width: none;
  }
  .filters-scroll::-webkit-scrollbar { display: none; }
  .filters {
    display: flex; gap: 8px; align-items: center; white-space: nowrap;
  }
  .filter-btn {
    background: var(--home-card); color: var(--home-muted);
    border: 1px solid var(--home-border); border-radius: 999px;
    padding: 6px 14px; font-size: 0.78rem; font-family: inherit; font-weight: 500;
    cursor: pointer; transition: all var(--dur) var(--ease);
  }
  .filter-btn:hover {
    background: var(--home-card); border-color: var(--home-muted); color: var(--home-text);
  }
  .filter-btn.active {
    background: var(--home-card); color: var(--home-text); border-color: var(--home-muted);
  }

  /* ── RECENT CAROUSEL ── */
  .recent-scroll {
    display: flex; gap: 8px; overflow-x: auto; 
    padding: 8px 4px 20px 4px; margin: -8px -4px -12px -4px;
    scrollbar-width: none;
  }
  .recent-scroll::-webkit-scrollbar { display: none; }
  .recent-scroll .card {
    min-width: 155px;
    height: 84px;
    flex-shrink: 0;
    border-radius: 6px;
  }

  /* ── GRID ── */
  .grid-head { padding: 0 0 14px; }
  .grid-label {
    font-size: 0.76rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.16em; color: var(--home-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
    gap: 8px;
    padding-bottom: 16px;
  }

  #subject-grid .card {
    height: auto;
    min-height: 72px;
    border-radius: 6px;
    transition: background-color var(--dur) var(--ease), border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  #subject-grid .card:hover,
  #subject-grid .card:focus-within {
    background: #3a3a3a;
    border-color: #555555;
    box-shadow: none;
    transform: none;
  }
  :root.light #subject-grid .card:hover,
  :root.light #subject-grid .card:focus-within {
    background: #f3efe8;
    border-color: rgba(0, 0, 0, 0.18);
  }
  #subject-grid .card-link {
    padding: 14px 16px;
    justify-content: space-between;
  }
  #subject-grid .card-code {
    color: var(--home-text);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  #subject-grid .card-papers {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #666666;
    font-size: 11px;
    font-weight: 400;
    line-height: 1.2;
  }
  #subject-grid .paper-density {
    display: inline-flex;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.6;
  }
  .recent-scroll .paper-density {
    display: none;
  }
  :is(#subject-grid, #recent-carousel) .card-actions {
    top: 8px;
    right: 8px;
    bottom: auto;
    z-index: 12;
  }
  :is(#subject-grid, #recent-carousel) .star-btn {
    min-width: 24px;
    min-height: 24px;
    padding: 4px;
    color: #888888;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    background: transparent !important;
  }
  :is(#subject-grid, #recent-carousel) .star-icon {
    display: block;
    width: 16px;
    height: 16px;
    opacity: 0.4;
    visibility: hidden;
    fill: transparent;
    stroke: currentColor;
    transition: opacity var(--dur) var(--ease), fill var(--dur) var(--ease), stroke var(--dur) var(--ease);
  }
  :is(#subject-grid, #recent-carousel) .card.favorited .star-btn {
    color: #f0ebe0;
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  :is(#subject-grid, #recent-carousel) .card.favorited .star-icon {
    fill: #f0ebe0;
    stroke: #f0ebe0;
    opacity: 1;
    visibility: visible;
  }
  @media (pointer: fine) {
    :is(#subject-grid, #recent-carousel) .card:hover .star-btn,
    :is(#subject-grid, #recent-carousel) .card:focus-within .star-btn {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    :is(#subject-grid, #recent-carousel) .card:hover .star-icon,
    :is(#subject-grid, #recent-carousel) .card:focus-within .star-icon {
      opacity: 0.4;
      visibility: visible;
    }
    :is(#subject-grid, #recent-carousel) .star-btn:hover .star-icon,
    :is(#subject-grid, #recent-carousel) .star-btn:focus-visible .star-icon {
      opacity: 1;
      visibility: visible;
    }
  }
  @media (pointer: coarse) {
    :is(#subject-grid, #recent-carousel) .card-actions {
      top: auto;
      right: 4px;
      bottom: 4px;
    }
    :is(#subject-grid, #recent-carousel) .star-btn {
      min-width: 44px;
      min-height: 44px;
      padding: 14px;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
    :is(#subject-grid, #recent-carousel) .star-icon {
      opacity: 0.35;
      visibility: visible;
    }
    :is(#subject-grid, #recent-carousel) .card-link {
      padding-right: 60px;
    }
  }

  .card {
    position: relative;
    height: 88px;
    background: var(--home-card);
    border: 1px solid var(--home-border);
    border-radius: 16px;
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .card:hover {
    background: var(--home-card);
    border-color: var(--home-muted);
  }
  .card-link {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 16px; padding-right: 48px; outline: none;
  }
  .card-code {
    font-size: 0.88rem; font-weight: 500;
    letter-spacing: 0.01em; color: var(--home-text);
  }
  .card-papers {
    font-size: 0.7rem; font-weight: 400; color: var(--home-muted);
  }
  
  .card-actions {
    position: absolute; top: 8px; right: 8px; z-index: 10;
    display: flex; align-items: center; gap: 4px;
  }
  .star-btn {
    width: 28px; height: 28px; border-radius: 50%;
    color: var(--home-muted); background: transparent !important;
    transition: color var(--dur) var(--ease), opacity var(--dur) var(--ease); opacity: 0.9;
  }
  .star-btn:hover { color: var(--home-text); opacity: 1; }
  .card.favorited .star-btn { color: var(--home-text); opacity: 1; }
  .card.favorited .star-icon { fill: var(--home-text); stroke: var(--home-text); }

  /* ── EMPTY ── */
  .empty {
    text-align: center; padding: 60px 0;
    font-size: 0.85rem; color: var(--home-muted);
  }

  .clear-btn {
    background: none; border: none; outline: none;
    font-size: 0.72rem; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--home-muted);
    cursor: pointer; transition: color var(--dur) var(--ease);
    padding: 4px 8px; margin-right: -8px;
  }
  .clear-btn:hover { color: var(--home-text); }

  /* ── FOOTER ── */
  .foot {
    border-top: 1px solid #333333;
    padding: 28px 0;
  }
  .foot-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .foot-copy {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    min-width: 0;
  }
  .foot-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #555555;
  }
  .foot-note {
    font-size: 11px;
    color: #555555;
  }
  .foot-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 0;
    border: none;
    border-radius: 0;
    background: transparent;
    color: #666666;
    font-size: 12px;
    font-weight: 500;
    transition: color 0.2s ease;
    white-space: nowrap;
  }
  .foot-link:hover {
    color: #f0ebe0;
  }
  .foot-arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }
  .foot-link:hover .foot-arrow {
    transform: translateX(3px);
  }
  :root.light .foot {
    border-top-color: rgba(0, 0, 0, 0.08);
  }
  :root.light .foot-label,
  :root.light .foot-note {
    color: #7a746c;
  }
  :root.light .foot-link { color: #6f6a63; }
  :root.light .foot-link:hover {
    color: #2d2a26;
  }

  @media (max-width: 640px) {
    .home-page .container {
      padding-left: 24px;
      padding-right: 24px;
    }
    .hero { padding: 32px 0 0; }
    .hero-shell { gap: 24px; }
    .hero-top {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
    }
    .hero-text { padding-top: 0; }
    .hero-tag {
      gap: 10px;
      margin-bottom: 14px;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
    }
    .hero-tag::before { width: 24px; }
    .hero-title {
      margin-bottom: 14px;
      font-size: clamp(3.2rem, 17vw, 5rem);
      line-height: 0.92;
    }
    .hero-sub {
      gap: 8px;
      flex-wrap: wrap;
      width: auto;
      font-size: 0.9rem;
    }
    .hero-tools {
      padding-top: 2px;
    }
    .hero-theme-btn {
      width: 42px;
      height: 42px;
    }
    .foot-inner {
      flex-direction: column;
      align-items: center;
      gap: 10px;
      text-align: center;
    }
    .foot-copy {
      flex-direction: column;
      gap: 4px;
      align-items: center;
    }
    .foot-label,
    .foot-note,
    .foot-link {
      font-size: 11px;
    }
    .search-section {
      margin-top: 0;
    }
    .search-box {
      height: 50px;
      padding: 0 15px;
    }
    .search-box input {
      font-size: 0.88rem;
    }
    .recent-section,
    .filters-section,
    main.container {
      margin-top: 28px;
    }
    .grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 5px; }
    .card { height: 76px; padding: 13px; }
  }


</style>

<script>
  import { buildSubjectSearchIndex, scoreSubjectSearch } from "../lib/subjectSearch.ts";

  const input = document.getElementById("search-input") as HTMLInputElement;
  const grid = document.getElementById("subject-grid")!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>(".card"));
  const cardsByCode = new Map(cards.map((card) => [card.dataset.code || "", card]));
  const subjectSearchSeedNode = document.getElementById("subject-search-data");
  const subjectSearchSeeds = subjectSearchSeedNode?.textContent ? JSON.parse(subjectSearchSeedNode.textContent) : [];
  const subjectSearchIndex = buildSubjectSearchIndex(subjectSearchSeeds);
  const searchEntriesByCode = new Map(subjectSearchIndex.map((entry) => [entry.code, entry]));
  const label = document.getElementById("results-count")!;
  const empty = document.getElementById("no-results")!;
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
  
  const progSelect = document.getElementById("program-select") as HTMLSelectElement;
  const semWrapper = document.getElementById("semester-wrapper")!;
  const semBtns = Array.from(document.querySelectorAll<HTMLButtonElement>(".sem-btn"));
  const allSemBtn = document.querySelector<HTMLButtonElement>("[data-sem='all']")!;

  const NO_PROGRAM = "none";
  const ALL_SEMESTERS = "all";
  let activeSubjects: string[] | null = null;
  let activeFilterLabel = "";
  const FAV_KEY = 'ku-favorites';

  function readStoredList(key: string) {
    try {
      const rawValue = localStorage.getItem(key);
      if (!rawValue) return [];
      const parsedValue = JSON.parse(rawValue);
      return Array.isArray(parsedValue) ? parsedValue : [];
    } catch {
      localStorage.removeItem(key);
      return [];
    }
  }

  let favorites: Set<string> = new Set(
    readStoredList(FAV_KEY).filter((value): value is string => typeof value === "string" && value.length > 0)
  );

  function saveStorage() {
    localStorage.setItem(FAV_KEY, JSON.stringify(Array.from(favorites)));
  }

  function getSubjectsForButton(btn: HTMLButtonElement) {
    return (btn.dataset.subjects || "").split(",").filter(Boolean);
  }

  function renderCollectionStates() {
    const favoriteCards: HTMLElement[] = [];
    const regularCards: HTMLElement[] = [];

    cards.forEach((card) => {
      const code = card.dataset.code || "";
      const isFavorite = favorites.has(code);
      card.classList.toggle('favorited', isFavorite);
      if (isFavorite) favoriteCards.push(card);
      else regularCards.push(card);
    });

    [...favoriteCards, ...regularCards].forEach((card) => grid.appendChild(card));
  }

  function toggleFavorite(code: string) {
    if (!code) return;
    if (favorites.has(code)) favorites.delete(code);
    else favorites.add(code);
    saveStorage();
    renderCollectionStates();
    renderRecents();
    update();
  }

  function attachFavoriteListener(button: HTMLButtonElement) {
    button.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const card = button.closest<HTMLElement>('.card');
      toggleFavorite(card?.dataset.code || "");
    });
  }

  cards.forEach((card) => {
    const starButton = card.querySelector<HTMLButtonElement>('.star-btn');
    if (starButton) attachFavoriteListener(starButton);
  });
  renderCollectionStates();

  const recentContainer = document.getElementById("recent-container")!;
  const recentCarousel = document.getElementById("recent-carousel")!;
  const clearRecentButton = document.getElementById("clear-recent") as HTMLButtonElement | null;
  const RECENT_KEY = 'ku-recent';
  const RECENT_VIEW_KEY = 'ku-recent-enabled';

  function isRecentViewEnabled() {
    return localStorage.getItem(RECENT_VIEW_KEY) !== 'false';
  }

  function clearRecentHistory() {
    localStorage.removeItem(RECENT_KEY);
    renderRecents();
  }
  
  function renderRecents() {
    recentCarousel.innerHTML = "";

    if (!isRecentViewEnabled()) {
      localStorage.removeItem(RECENT_KEY);
      recentContainer.style.display = "none";
      if (clearRecentButton) clearRecentButton.disabled = true;
      return;
    }

    const history = readStoredList(RECENT_KEY);
    const sanitizedHistory = history.filter((code, index) => {
      return typeof code === "string" && code && cardsByCode.has(code) && history.indexOf(code) === index;
    }).slice(0, 6);

    if (sanitizedHistory.length !== history.length) {
      localStorage.setItem(RECENT_KEY, JSON.stringify(sanitizedHistory));
    }

    if (sanitizedHistory.length === 0) {
      recentContainer.style.display = "none";
      if (clearRecentButton) clearRecentButton.disabled = true;
      return;
    }

    recentContainer.style.display = "";
    if (clearRecentButton) clearRecentButton.disabled = false;

    sanitizedHistory.forEach((code) => {
      const sourceCard = cardsByCode.get(code);
      if (!sourceCard) return;

      const clone = sourceCard.cloneNode(true) as HTMLElement;
      clone.classList.remove('anim');
      clone.style.animationDelay = '0ms';
      clone.style.display = '';
      recentCarousel.appendChild(clone);

      const starButton = clone.querySelector<HTMLButtonElement>('.star-btn');
      if (starButton) {
        attachFavoriteListener(starButton);
      }
    });
  }

  clearRecentButton?.addEventListener("click", (event) => {
    event.preventDefault();
    clearRecentHistory();
  });

  renderRecents();

  window.addEventListener("recent-view-changed", () => {
    renderRecents();
  });

  function updateResultsLabel(count: number, hasQuery: boolean) {
    if (!hasQuery && !activeFilterLabel) {
      label.textContent = "All subjects";
      return;
    }

    const noun = hasQuery ? "result" : "subject";
    const baseLabel = `${count} ${noun}${count !== 1 ? "s" : ""}`;
    label.textContent = activeFilterLabel ? `${baseLabel} in ${activeFilterLabel}` : baseLabel;
  }

  function update() {
    const q = input.value.trim();
    const matches: { card: HTMLElement; code: string; score: number }[] = [];

    for (const c of cards) {
      const code = c.dataset.code || "";
      const matchFilter = !activeSubjects || activeSubjects.includes(code);
      const searchEntry = searchEntriesByCode.get(code);
      const resolvedScore = q && searchEntry ? scoreSubjectSearch(searchEntry, q) : q ? -1 : 0;
      const show = matchFilter && (!q || resolvedScore >= 0);
      c.style.display = show ? "" : "none";
      if (show) matches.push({ card: c, code, score: resolvedScore });
    }

    if (q) {
      matches
        .sort((left, right) => {
          if (right.score !== left.score) return right.score - left.score;
          if (favorites.has(left.code) !== favorites.has(right.code)) {
            return Number(favorites.has(right.code)) - Number(favorites.has(left.code));
          }
          return left.code.localeCompare(right.code);
        })
        .forEach(({ card }) => {
          grid.appendChild(card);
        });
    } else {
      renderCollectionStates();
    }

    updateResultsLabel(matches.length, Boolean(q));
    empty.style.display = matches.length === 0 ? "" : "none";
  }

  function setActiveButton(button: HTMLButtonElement) {
    filterBtns.forEach((filterButton) => filterButton.classList.remove("active"));
    button.classList.add("active");
  }

  function applySemesterFilter(button: HTMLButtonElement) {
    setActiveButton(button);
    const selectedProgram = progSelect.value;
    const selectedSubjects = getSubjectsForButton(button);

    if (button.dataset.sem === ALL_SEMESTERS) {
      activeSubjects = selectedSubjects.length > 0 ? selectedSubjects : null;
      activeFilterLabel = selectedProgram === NO_PROGRAM ? "" : selectedProgram;
    } else {
      activeSubjects = selectedSubjects;
      activeFilterLabel = selectedProgram === NO_PROGRAM
        ? (button.dataset.label || button.textContent || "").trim()
        : `${selectedProgram} · ${(button.dataset.label || button.textContent || "").trim()}`;
    }

    update();
  }

  function syncSemesterButtons(programName: string) {
    const visibleButtons: HTMLButtonElement[] = [];

    semBtns.forEach((button) => {
      const isVisible = button.dataset.prog === programName;
      button.style.display = isVisible ? "" : "none";
      if (isVisible) visibleButtons.push(button);
    });

    allSemBtn.dataset.subjects = Array.from(
      new Set(visibleButtons.flatMap((button) => getSubjectsForButton(button)))
    ).join(",");
  }

  function syncProgramSelection() {
    const programName = progSelect.value;

    if (programName === NO_PROGRAM) {
      semWrapper.style.display = "none";
      semBtns.forEach((button) => {
        button.style.display = "none";
      });
      allSemBtn.dataset.subjects = "";
      activeSubjects = null;
      activeFilterLabel = "";
      setActiveButton(allSemBtn);
      update();
    } else {
      semWrapper.style.display = "";
      syncSemesterButtons(programName);
      applySemesterFilter(allSemBtn);
    }
  }

  progSelect.addEventListener("change", syncProgramSelection);

  filterBtns.forEach((button) => {
    button.addEventListener("click", () => {
      applySemesterFilter(button);
    });
  });

  input.addEventListener("input", update);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") { input.value = ""; update(); input.blur(); }
    if (e.key === "/" && document.activeElement !== input) { e.preventDefault(); input.focus(); }
  });

  syncProgramSelection();
</script>
