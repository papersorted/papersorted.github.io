---
import manifest from "../data/manifest.json";
import { buildSubjectSearchSeeds } from "../data/searchAliases.ts";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Browse and download past examination papers by subject code.",
  image = "/favicon.png"
} = Astro.props;

const subjects = Object.keys(manifest).sort();
const subjectSearchSeeds = buildSubjectSearchSeeds(subjects);
const subjectSearchSeedJson = JSON.stringify(subjectSearchSeeds).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem('ku-app-theme');
          document.documentElement.classList.toggle('light', storedTheme === 'light');
        } catch {
          // Ignore storage access issues and fall back to the default theme.
        }
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <title>{title} · KU Papers</title>
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} · KU Papers`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${title} · KU Papers`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

      :root {
        --bg: #2b2b2b;
        --bg-card: rgba(255,255,255,0.035);
        --bg-card-hover: rgba(255,255,255,0.06);
        --bg-input: rgba(255,255,255,0.04);
        --bg-modal: rgba(31,31,31,0.96);
        --border: rgba(255,255,255,0.08);
        --border-hover: rgba(255,255,255,0.14);
        --border-focus: rgba(255,255,255,0.22);
        --text: #eae6e0;
        --text-secondary: #a39e98;
        --text-muted: #78736d;
        --text-faint: #56524e;
        --accent: #c4a882;
        --accent-dim: rgba(196,168,130,0.1);
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.2);
        --shadow-card: 0 2px 8px rgba(0,0,0,0.15);
        --shadow-card-hover: 0 4px 16px rgba(0,0,0,0.25);
        --ease: cubic-bezier(0.16, 1, 0.3, 1);
        --dur: 0.25s;
        --theme-dur: 0.4s;
        --theme-ease: cubic-bezier(0.22, 1, 0.36, 1);
        --viewer-bar-bg: rgba(20,20,20,0.78);
        --viewer-bg-top: #1b1c1f;
        --viewer-bg: #101113;
        --grain-opacity: 0.48;
        --theme-toggle-glow: rgba(234,230,224,0.08);
        --palette-overlay-bg: rgba(5,5,5,0.72);
        --palette-modal-bg: rgba(31,31,31,0.965);
        --palette-modal-border: rgba(255,255,255,0.085);
        --palette-modal-shadow: 0 24px 72px rgba(0,0,0,0.52), inset 0 1px 0 rgba(255,255,255,0.025);
        --palette-input-bg: rgba(255,255,255,0.018);
        --palette-divider: rgba(255,255,255,0.07);
        --palette-item-bg-hover: rgba(255,255,255,0.05);
        --palette-item-bg-active: rgba(255,255,255,0.07);
        --r: 8px;
        --r-sm: 5px;
        color-scheme: dark;
      }

      :root.light {
        --bg: #f5f4ef;
        --bg-card: #ffffff;
        --bg-card-hover: #fcfcfc;
        --bg-input: #ffffff;
        --bg-modal: #ffffff;
        --border: rgba(0,0,0,0.08);
        --border-hover: rgba(0,0,0,0.14);
        --border-focus: rgba(0,0,0,0.22);
        --text: #2d2a26;
        --text-secondary: #5e5a54;
        --text-muted: #8c8882;
        --text-faint: #b3b0ab;
        --accent: #a68b63;
        --accent-dim: rgba(166,139,99,0.08);
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
        --shadow-card: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-card-hover: 0 8px 24px rgba(0,0,0,0.08);
        --viewer-bar-bg: rgba(245,244,239,0.82);
        --viewer-bg-top: #f6f1e8;
        --viewer-bg: #e9e1d5;
        --grain-opacity: 0.18;
        --theme-toggle-glow: rgba(166,139,99,0.14);
        --palette-overlay-bg: rgba(26,22,18,0.16);
        --palette-modal-bg: rgba(255,255,255,0.94);
        --palette-modal-border: rgba(0,0,0,0.08);
        --palette-modal-shadow: 0 18px 48px rgba(0,0,0,0.12), inset 0 1px 0 rgba(255,255,255,0.6);
        --palette-input-bg: rgba(0,0,0,0.015);
        --palette-divider: rgba(0,0,0,0.06);
        --palette-item-bg-hover: rgba(0,0,0,0.03);
        --palette-item-bg-active: rgba(0,0,0,0.045);
        color-scheme: light;
      }

      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
        background: var(--bg);
      }

      body {
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
        transition:
          background-color var(--theme-dur) var(--theme-ease),
          color var(--theme-dur) var(--theme-ease);
      }

      /* ── Paper grain texture ── */
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: var(--grain-opacity);
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px 200px;
        mix-blend-mode: overlay;
        transition: opacity var(--theme-dur) var(--theme-ease);
      }

      a { color: inherit; text-decoration: none; }

      .serif {
        font-family: 'Playfair Display', Georgia, 'Times New Roman', serif;
      }
      .mono { font-family: 'JetBrains Mono', 'SF Mono', monospace; }

      .container { max-width: 1040px; margin: 0 auto; padding: 0 32px; }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 10px; }

      /* Animations */
      @keyframes enter {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .anim { animation: enter 0.45s var(--ease) both; }

      ::selection { background: rgba(196,168,130,0.22); color: #fff; }

      /* Breadcrumbs */
      .breadcrumb {
        display: flex; align-items: center; gap: 8px;
        padding: 24px 0 8px; font-size: 0.78rem; font-weight: 500;
      }
      .breadcrumb a { color: var(--text-muted); transition: color var(--dur) var(--ease); }
      .breadcrumb a:hover { color: var(--accent); }
      .breadcrumb .sep { color: var(--text-faint); font-size: 0.65rem; }
      .breadcrumb .current { color: var(--text-secondary); }

      /* Global Reset for Buttons */
      button {
        all: unset;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        appearance: none; -webkit-appearance: none;
        background: transparent;
        color: inherit;
        border: none; padding: 0; outline: none;
      }

      /* Theme Toggle Icons */
      .theme-toggle-btn {
        position: relative;
        isolation: isolate;
        overflow: hidden;
        transform: translateZ(0);
      }
      .theme-toggle-btn::before {
        content: "";
        position: absolute;
        inset: 3px;
        border-radius: inherit;
        background: radial-gradient(circle at 50% 35%, var(--theme-toggle-glow), transparent 70%);
        opacity: 0.8;
        transition:
          opacity var(--theme-dur) var(--theme-ease),
          transform var(--theme-dur) var(--theme-ease);
      }
      .theme-toggle-btn svg {
        position: absolute;
        inset: 0;
        margin: auto;
        pointer-events: none;
        transform-origin: 50% 50%;
        transition:
          opacity var(--theme-dur) var(--theme-ease),
          transform var(--theme-dur) var(--theme-ease),
          filter var(--theme-dur) var(--theme-ease);
      }
      .theme-toggle-btn .sun {
        opacity: 0;
        transform: translateY(2px) scale(0.82) rotate(-24deg);
        filter: drop-shadow(0 0 0 rgba(166,139,99,0));
      }
      .theme-toggle-btn .moon {
        opacity: 1;
        transform: translateY(0) scale(1) rotate(0deg);
        filter: drop-shadow(0 0 8px rgba(255,255,255,0.05));
      }
      :root.light .theme-toggle-btn::before {
        transform: scale(1.04);
      }
      :root.light .theme-toggle-btn .moon {
        opacity: 0;
        transform: translateY(-2px) scale(0.82) rotate(22deg);
        filter: drop-shadow(0 0 0 rgba(255,255,255,0));
      }
      :root.light .theme-toggle-btn .sun {
        opacity: 1;
        transform: translateY(0) scale(1) rotate(0deg);
        filter: drop-shadow(0 0 10px rgba(166,139,99,0.18));
      }

      :where(.palette-modal, .palette-input-wrap, .palette-item, .palette-item .icon, .palette-input-wrap svg, .palette-input-wrap input) {
        transition:
          background-color var(--theme-dur) var(--theme-ease),
          border-color var(--theme-dur) var(--theme-ease),
          color var(--theme-dur) var(--theme-ease),
          box-shadow var(--theme-dur) var(--theme-ease),
          opacity var(--theme-dur) var(--theme-ease);
      }

      @media (prefers-reduced-motion: reduce) {
        body,
        body::after,
        .theme-toggle-btn::before,
        .theme-toggle-btn svg {
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />

    <!-- Command Palette -->
    <script id="subject-search-data" type="application/json" set:html={subjectSearchSeedJson}></script>
    <style is:inline>
      .palette-overlay {
        position: fixed; inset: 0; z-index: 10000;
        background: var(--palette-overlay-bg);
        backdrop-filter: blur(10px) saturate(118%);
        -webkit-backdrop-filter: blur(10px) saturate(118%);
        display: flex; align-items: flex-start; justify-content: center;
        padding-top: 12vh; opacity: 0; pointer-events: none;
        transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .palette-overlay.open { opacity: 1; pointer-events: auto; }
      
      .palette-modal {
        width: 100%; max-width: 580px;
        background:
          linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0) 38%),
          var(--palette-modal-bg, var(--bg-modal, #2b2b2b));
        border: 1px solid var(--palette-modal-border, var(--border));
        border-radius: 8px;
        box-shadow: var(--palette-modal-shadow);
        backdrop-filter: blur(22px) saturate(128%);
        -webkit-backdrop-filter: blur(22px) saturate(128%);
        transform: scale(0.96) translateY(10px);
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        overflow: hidden; display: flex; flex-direction: column;
      }
      .palette-overlay.open .palette-modal { transform: scale(1) translateY(0); }

      .palette-input-wrap {
        display: flex; align-items: center; padding: 0 16px;
        background: var(--palette-input-bg);
        border-bottom: 1px solid var(--palette-divider, var(--border));
      }
      .palette-input-wrap svg { color: var(--text-muted); }
      .palette-input-wrap input {
        width: 100%; padding: 18px 12px; background: transparent; border: none;
        font-size: 1.1rem; color: var(--text); outline: none; font-family: inherit;
      }
      .palette-input-wrap input::placeholder { color: var(--text-muted); }

      .palette-results {
        max-height: 380px; overflow-y: auto; padding: 8px 0;
        list-style: none; margin: 0;
      }
      .palette-item {
        padding: 10px 18px; margin: 0 8px; border-radius: 5px;
        display: flex; align-items: center; gap: 12px;
        color: var(--text-secondary); cursor: pointer;
        transition: background-color 0.14s ease, color 0.14s ease;
      }
      .palette-item.active, .palette-item:hover {
        color: var(--text);
      }
      .palette-item:hover {
        background: var(--palette-item-bg-hover, var(--bg-card-hover));
      }
      .palette-item.active {
        background: var(--palette-item-bg-active, var(--bg-card-hover));
      }
      .palette-item .icon { color: var(--text-faint); }
      .palette-item.active .icon { color: var(--accent); }
    </style>
    <div id="cmd-palette" class="palette-overlay">
      <div class="palette-modal" id="cmd-modal">
        <div class="palette-input-wrap">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="cmd-input" placeholder="Jump to a subject or area, type > for actions, or ? for Deep Search..." autocomplete="off" spellcheck="false" />
        </div>
        <ul class="palette-results" id="cmd-results"></ul>
      </div>
    </div>
    
    <script>
      import { buildSubjectSearchIndex, searchSubjectEntries } from "../lib/subjectSearch.ts";

      // Unified Theme Logic
      const THEME_KEY = 'ku-app-theme';
      const RECENT_KEY = 'ku-recent';
      const RECENT_VIEW_KEY = 'ku-recent-enabled';
      const subjectSearchSeedNode = document.getElementById('subject-search-data');
      const subjectSearchSeeds = subjectSearchSeedNode?.textContent ? JSON.parse(subjectSearchSeedNode.textContent) : [];
      const subjectSearchIndex = buildSubjectSearchIndex(subjectSearchSeeds);
      
      window.setAppTheme = (isLight) => {
        document.documentElement.classList.toggle('light', isLight);
        localStorage.setItem(THEME_KEY, isLight ? 'light' : 'dark');
        localStorage.setItem('ku-pdf-dark-mode', !isLight ? 'true' : 'false');
        // Dispatch event for other components to react
        window.dispatchEvent(new Event('theme-changed'));
      };

      window.isRecentViewEnabled = () => localStorage.getItem(RECENT_VIEW_KEY) !== 'false';
      window.setRecentViewEnabled = (enabled) => {
        localStorage.setItem(RECENT_VIEW_KEY, enabled ? 'true' : 'false');
        if (!enabled) {
          localStorage.removeItem(RECENT_KEY);
        }
        window.dispatchEvent(new CustomEvent('recent-view-changed', {
          detail: { enabled }
        }));
      };

      document.addEventListener('click', (e) => {
        if (e.target.closest('.theme-toggle-btn')) {
          const isCurrentlyLight = document.documentElement.classList.contains('light');
          window.setAppTheme(!isCurrentlyLight);
        }
      });

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', async () => {
          const isLocalDevHost = ['localhost', '127.0.0.1'].includes(window.location.hostname);

          if (isLocalDevHost) {
            const registrations = await navigator.serviceWorker.getRegistrations();
            await Promise.all(registrations.map((registration) => registration.unregister()));

            if ('caches' in window) {
              const cacheKeys = await caches.keys();
              await Promise.all(
                cacheKeys
                  .filter((key) => key.startsWith('ku-papers-'))
                  .map((key) => caches.delete(key))
              );
            }
            return;
          }

          navigator.serviceWorker.register('/sw.js').catch((err) => {
            console.error('ServiceWorker registration failed: ', err);
          });
        });
      }

      // Command Palette Logic
      const overlay = document.getElementById('cmd-palette');
      const modal = document.getElementById('cmd-modal');
      const input = document.getElementById('cmd-input');
      const resultsUL = document.getElementById('cmd-results');
      
      let isOpen = false;
      let activeIndex = 0;
      let filtered = [];
      let deepIndexMap = null; // caches the inverted index

      function getCommands() {
        const isLightTheme = document.documentElement.classList.contains('light');
        const recentViewEnabled = window.isRecentViewEnabled();

        return [
          { id: 'cmd-home', title: 'Go to Homepage', icon: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>', action: '/' },
          {
            id: 'cmd-theme',
            title: isLightTheme ? 'Switch to Dark Mode' : 'Switch to Light Mode',
            icon: isLightTheme
              ? '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>'
              : '<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>',
            action: isLightTheme ? 'SET_DARK_MODE' : 'SET_LIGHT_MODE'
          },
          {
            id: 'cmd-recent',
            title: recentViewEnabled ? 'Disable Recently Viewed' : 'Enable Recently Viewed',
            icon: '<path d="M12 8v4l3 3"></path><circle cx="12" cy="12" r="9"></circle>',
            action: 'TOGGLE_RECENT_VIEW'
          }
        ];
      }

      async function fetchDeepIndex() {
        if (deepIndexMap !== null) return deepIndexMap;
        try {
          const res = await fetch('/search_index.json');
          if (!res.ok) throw new Error("Index not found");
          deepIndexMap = await res.json();
          return deepIndexMap;
        } catch (err) {
          deepIndexMap = false; // Disable if missing or not built yet
          return false;
        }
      }

      function openPalette() {
        isOpen = true;
        overlay.classList.add('open');
        input.value = '';
        renderResults('');
        setTimeout(() => input.focus(), 50);
        fetchDeepIndex(); // pre-fetch quietly
      }

      function closePalette() {
        isOpen = false;
        overlay.classList.remove('open');
        input.blur();
      }

      function setThemeMode(isLight) {
        window.setAppTheme(isLight);
        closePalette();
      }

      function toggleRecentView() {
        const nextEnabled = !window.isRecentViewEnabled();
        window.setRecentViewEnabled(nextEnabled);
        closePalette();
      }

      function executeAction(item) {
        if (!item) return;
        if (item.action === 'SET_DARK_MODE') setThemeMode(false);
        else if (item.action === 'SET_LIGHT_MODE') setThemeMode(true);
        else if (item.action === 'TOGGLE_RECENT_VIEW') toggleRecentView();
        else window.location.href = item.action;
      }

      function renderResults(q) {
        let items = [];
        const startsCmd = q.startsWith('>');
        const startsDeep = q.startsWith('?');
        
        if (startsCmd) {
          const sc = q.slice(1).trim().toLowerCase();
          items = getCommands().filter(c => c.title.toLowerCase().includes(sc));
        } else if (startsDeep) {
          const dq = q.slice(1).trim().toLowerCase();
          if (dq.length < 3) {
            resultsUL.innerHTML = '<li class="palette-item" style="justify-content:center"><span class="mono" style="color:var(--text-faint); font-size:0.85rem;">Type 3 letters to deep-search PDFs...</span></li>';
            return;
          }
          if (deepIndexMap === false) {
             resultsUL.innerHTML = '<li class="palette-item" style="justify-content:center"><span class="mono" style="color:#d94848; font-size:0.85rem;">Index missing. Run `npm run build:index` first.</span></li>';
             return;
          }
          if (deepIndexMap === null) {
             resultsUL.innerHTML = '<li class="palette-item" style="justify-content:center"><span class="mono" style="color:var(--accent); font-size:0.85rem;">Loading 2GB index mapping...</span></li>';
             fetchDeepIndex().then(() => renderResults(q));
             return;
          }

          const hits = new Map();
          const targetWord = dq.split(' ')[0]; // We just do single word for now for massive speed
          
          Object.keys(deepIndexMap).forEach(w => {
            if (w.includes(targetWord)) {
              deepIndexMap[w].forEach(doc => {
                 hits.set(doc, (hits.get(doc) || 0) + 1);
              });
            }
          });

          const ranked = Array.from(hits.entries()).sort((a,b) => b[1] - a[1]).slice(0, 30);
          
          if (ranked.length === 0) {
             resultsUL.innerHTML = '<li class="palette-item" style="justify-content:center"><span class="mono" style="color:var(--text-faint); font-size:0.85rem;">No exact PDF matches found...</span></li>';
             return;
          }

          items = ranked.map(r => {
            const [subj, file] = r[0].split('/');
            return {
              title: `${subj} <span style="opacity:0.4;font-size:0.8rem">- ${file.replace('.pdf','')}</span>`,
              action: `/viewer/${subj}/${file}/`,
              icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline>'
            };
          });
        } else {
          items = searchSubjectEntries(subjectSearchIndex, q, 50).map((entry) => ({
            title: entry.code,
            action: `/subject/${entry.code}/`,
            icon: '<path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>'
          }));
        }

        filtered = items;
        activeIndex = 0;

        if (items.length === 0) {
          resultsUL.innerHTML = '<li class="palette-item" style="justify-content:center"><span class="mono" style="color:var(--text-faint); font-size:0.85rem;">No subjects match that search.</span></li>';
          return;
        }

        resultsUL.innerHTML = items.map((item, i) => `
          <li class="palette-item ${i === 0 ? 'active' : ''}" data-idx="${i}">
            <svg class="icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${item.icon}</svg>
            <span class="mono">${item.title}</span>
            ${item.action && !String(item.action).startsWith('/') ? '<span style="margin-left:auto;font-size:0.7rem;color:#78736d">Action</span>' : ''}
          </li>
        `).join('');
      }

      function updateActive() {
        const lis = resultsUL.querySelectorAll('li');
        lis.forEach((li, i) => li.classList.toggle('active', i === activeIndex));
        if (lis[activeIndex]) lis[activeIndex].scrollIntoView({ block: 'nearest' });
      }

      input.addEventListener('input', (e) => renderResults(e.target.value));

      input.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' && filtered.length > 0) { e.preventDefault(); activeIndex = (activeIndex + 1) % filtered.length; updateActive(); }
        if (e.key === 'ArrowUp' && filtered.length > 0) { e.preventDefault(); activeIndex = (activeIndex - 1 + filtered.length) % filtered.length; updateActive(); }
        if (e.key === 'Enter') { e.preventDefault(); executeAction(filtered[activeIndex]); }
      });

      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closePalette();
      });

      resultsUL.addEventListener('click', (e) => {
        const li = e.target.closest('li');
        if (li) executeAction(filtered[li.dataset.idx]);
      });

      window.addEventListener('theme-changed', () => {
        if (isOpen) renderResults(input.value);
      });

      window.addEventListener('recent-view-changed', () => {
        if (isOpen) renderResults(input.value);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
          e.preventDefault();
          isOpen ? closePalette() : openPalette();
        }
        if (e.key === 'Escape' && isOpen) {
          e.preventDefault();
          closePalette();
        }
      });
    </script>
  </body>
</html>
